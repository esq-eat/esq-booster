<?xml version="1.0" encoding="utf-8"?>
<!--
    ESQ Logo — stroke-based vector
    E: left bar + top/middle/bottom horizontals
    S: Z-path forming blocky S
    Q: rounded rectangle outline + tail
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Sky-blue background -->
    <path
        android:fillColor="#29ABEF"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"/>

    <!-- ── E ──
         Top bar: right→left
         Left vertical: down full height
         Bottom bar: left→right
         + separate middle bar
    -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:fillColor="#00000000"
        android:strokeLineCap="square"
        android:strokeLineJoin="miter"
        android:pathData="M34,27 L8,27 L8,81 L34,81"/>
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:fillColor="#00000000"
        android:strokeLineCap="square"
        android:pathData="M8,54 L30,54"/>

    <!-- ── S ──
         Path traces: top-right → top-left → middle-left → middle-right → bottom-right → bottom-left
         This creates the classic blocky Z/S shape
    -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:fillColor="#00000000"
        android:strokeLineCap="square"
        android:strokeLineJoin="miter"
        android:pathData="M63,27 L38,27 L38,54 L63,54 L63,81 L38,81"/>

    <!-- ── Q ──
         Rounded rectangle outline (even-odd fill = hollow)
    -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M71,27 L97,27 Q101,27 101,31 L101,77 Q101,81 97,81 L71,81 Q67,81 67,77 L67,31 Q67,27 71,27 Z"/>

    <!-- Q tail — horizontal bar below bottom-right -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M76,87 L101,87"/>

</vector>
